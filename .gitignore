# Local-only (never tracked)
.claude/settings.local.json
.env

# Factory runtime state (gate-block event log for `factory report`)
.factory/

# Go
*.test
*.out

# OS
.DS_Store

# Node
node_modules/

# Eval results — track baselines, ignore current-run (regenerated each time)
eval/results/*-current.json
eval/results/current-run.json
eval/results/last-run.json
# Mock-runner results are self-test artifacts, never real baselines
eval/results/mock-*.json

# Wiki is agent-maintained but tracked (lint-gated at merge)
# wiki/ is NOT ignored — it's committed and reviewed

# Memory/lessons are tracked (one lesson per file, committed)
# memory/lessons/ is NOT ignored

# Loop-close flag files (transient, per-session — never tracked)
memory/.pending-lesson-reminder
memory/PENDING-LESSONS.md
memory/.parity-stale

# Claude config is GENERATED from opencode.json — tracked for drift check
# .claude/ and .mcp.json are committed (not ignored)
# Exception: .claude/settings.local.json is local-only (above)

# Factory config (generated by factory-init — track it)
# factory.yaml is committed
